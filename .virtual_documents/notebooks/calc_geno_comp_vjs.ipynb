# Fast QC manifest (single-pass agg + sampled quantiles/top-k)
from pyspark.sql import functions as F
from pyspark.sql import types as T
import time

# --- CONFIG ---
fast_mode = True         # True = use sample everywhere (very fast, approximate).
                         # False = accurate counts/approx-distinct on full df (single-pass agg), quantiles on sample.
sample_frac = 0.005      # sample fraction for quantiles/top-k when fast_mode or for quantiles in accurate mode
quantile_relerr = 0.01   # relError for approxQuantile on sample
topk = 50                # top-k levels to inspect for categorical collapse hints

orig_df = df_reduced            # keep original name
N_total = orig_df.count()
start = time.time()

# choose base_df for *all* approximate ops in fast mode
if fast_mode:
    base_df = orig_df.sample(False, sample_frac, seed=42).persist()
    base_n = base_df.count()
else:
    base_df = orig_df   # for accurate single-pass agg
    base_n = N_total

cols = orig_df.columns

# 1) single aggregated job: non-null counts + approx distincts (on base_df in fast mode, full df in accurate mode)
nn_exprs = [F.sum(F.when(F.col(c).isNotNull(), 1).otherwise(0)).alias(c + "_nn") for c in cols]
ad_exprs = [F.approx_count_distinct(F.col(c)).alias(c + "_ad") for c in cols]
agg_row = base_df.agg(*nn_exprs, *ad_exprs).collect()[0].asDict()

# 2) compute denominators once (using same base_df for speed)
def denom_counts(df):
    q_cols = [c for c in cols if c.startswith("questionnaire.") or c.startswith("derived.") or c.startswith("participant.")]
    clinic_cols = [c for c in cols if c.startswith("clinic_measurements.")]
    hes_id_cols = [c for c in ["nhse_eng_inpat.row_id","nhse_eng_outpat.row_id","nhse_eng_ed.row_id","nhse_eng_inpat.epikey"] if c in cols]
    q_den = df.filter(F.reduce(lambda a,b: a | b, [F.col(c).isNotNull() for c in q_cols])) .count() if q_cols else 0
    clinic_den = df.filter(F.reduce(lambda a,b: a | b, [F.col(c).isNotNull() for c in clinic_cols])) .count() if clinic_cols else 0
    hes_den = df.filter(F.reduce(lambda a,b: a | b, [F.col(c).isNotNull() for c in hes_id_cols])) .count() if hes_id_cols else 0
    return q_den, clinic_den, hes_den

q_den, clinic_den, hes_den = denom_counts(base_df)

# 3) prepare numeric columns list for quantiles (only numeric dtypes)
dtypes = dict(orig_df.dtypes)
num_cols = [c for c,dt in dtypes.items() if dt in ("double","int","bigint","float","long","decimal")]

# quantiles/winsor: compute on the sample (base_df is already sampled in fast_mode; otherwise sample now)
if (not fast_mode) and (base_df is orig_df):
    q_sample = orig_df.sample(False, sample_frac, seed=42).persist()
else:
    q_sample = base_df

quantiles = {}
for c in num_cols:
    try:
        qs = q_sample.approxQuantile(c, [0.005, 0.995, 0.99], quantile_relerr)
        quantiles[c] = {"0.5_99.5": (float(qs[0]), float(qs[1])), "0.99": float(qs[2])}
    except Exception:
        quantiles[c] = {"0.5_99.5": (None, None), "0.99": None}

# 4) compute manifest rows using aggregated results (no per-column scan)
rows = []
for c in cols:
    nm = int(agg_row.get(c + "_nn", 0))
    approx_uniq = int(agg_row.get(c + "_ad", 0) or 0)
    pct_total = nm / N_total * 100.0 if N_total else 0.0

    # denom/ source mapping (derived & participant as questionnaire)
    if c.startswith("questionnaire.") or c.startswith("derived.") or c.startswith("participant."):
        src, denom = "questionnaire", q_den
    elif c.startswith("clinic_measurements."):
        src, denom = "clinic", clinic_den
    elif c.startswith("nhse_eng_") or c.startswith("nhse_eng."):
        src, denom = "hes", hes_den
    else:
        src, denom = "cohort", N_total

    pct_source = nm / denom * 100.0 if denom else 0.0
    # type heuristics
    is_numeric = dtypes.get(c) in ("double","int","bigint","float","long","decimal")
    is_binary = approx_uniq <= 2 and nm>0
    is_categorical = (not is_numeric) or (2 < approx_uniq < 50)
    is_continuous = is_numeric and (approx_uniq >= max(100, int(0.01 * max(1, denom))))

    # source-threshold
    if src == "questionnaire":
        keep_src = pct_source >= 80.0
    elif src == "clinic":
        keep_src = pct_source >= 50.0
    elif src == "hes":
        keep_src = nm >= 0.70 * denom if denom else False
    else:
        keep_src = True

    keep = keep_src
    notes = []

    # binary prevalence -> need top count: use sample groupBy on q_sample (cheap)
    prevalence_pct = None
    if is_binary and nm>0:
        topk = q_sample.groupBy(c).count().orderBy(F.desc("count")).limit(1).collect()
        if topk:
            top_count = topk[0][1]
            prevalence_pct = top_count / nm * 100.0
            if prevalence_pct < 0.1 or prevalence_pct > 99.9:
                keep = False
                notes.append(f"binary_prevalence_bad top={prevalence_pct:.3f}%")

    # categorical small levels: compute top-k on q_sample only (cheap)
    small_levels = None
    if is_categorical and nm>0:
        topk_df = q_sample.groupBy(c).count().orderBy(F.desc("count")).limit(topk)
        topk_pd = topk_df.withColumn("pct", F.col("count")/nm*100.0).toPandas()
        small_levels = int((topk_pd["pct"] < 1.0).sum())
        if small_levels>0:
            notes.append(f"categorical_small_levels_to_collapse:{small_levels}")

    # continuous rules & winsor bounds from quantiles computed earlier
    winsor_lo, winsor_hi, winsor_99 = None, None, None
    if is_continuous:
        qinfo = quantiles.get(c, {})
        if qinfo:
            winsor_lo, winsor_hi = qinfo["0.5_99.5"]
            winsor_99 = qinfo["0.99"]
        # min-cases/uniqueness rule
        if nm < 100 or approx_uniq < max(100, int(0.01 * max(1, denom))):
            keep = False
            notes.append("continuous_insufficient_cases_or_uniqueness")

    rows.append({
        "column": c, "source": src, "denom": int(denom),
        "non_missing": nm, "pct_non_missing_over_source": float(pct_source),
        "pct_non_missing_over_total": float(pct_total), "approx_unique": approx_uniq,
        "is_binary": bool(is_binary), "is_categorical": bool(is_categorical), "is_continuous": bool(is_continuous),
        "winsor_0_5_99_5_lower": winsor_lo, "winsor_0_5_99_5_upper": winsor_hi, "winsor_99": winsor_99,
        "keep_after_prevalence_and_rules": bool(keep), "notes": ";".join(notes) if notes else None
    })

# 5) build manifest DataFrame
schema = T.StructType([
    T.StructField("column", T.StringType()), T.StructField("source", T.StringType()),
    T.StructField("denom", T.LongType()), T.StructField("non_missing", T.LongType()),
    T.StructField("pct_non_missing_over_source", T.DoubleType()), T.StructField("pct_non_missing_over_total", T.DoubleType()),
    T.StructField("approx_unique", T.LongType()), T.StructField("is_binary", T.BooleanType()),
    T.StructField("is_categorical", T.BooleanType()), T.StructField("is_continuous", T.BooleanType()),
    T.StructField("winsor_0_5_99_5_lower", T.DoubleType()), T.StructField("winsor_0_5_99_5_upper", T.DoubleType()),
    T.StructField("winsor_99", T.DoubleType()), T.StructField("keep_after_prevalence_and_rules", T.BooleanType()),
    T.StructField("notes", T.StringType())
])
rows_conv = [[r[k] for k in ["column","source","denom","non_missing","pct_non_missing_over_source","pct_non_missing_over_total","approx_unique","is_binary","is_categorical","is_continuous","winsor_0_5_99_5_lower","winsor_0_5_99_5_upper","winsor_99","keep_after_prevalence_and_rules","notes"]] for r in rows]
manifest_df = spark.createDataFrame(rows_conv, schema=schema)

# 6) create winsorised columns lazily (use quantiles dict)
winsor_df = orig_df
for r in rows:
    c = r["column"]
    if r["is_continuous"] and r["winsor_0_5_99_5_lower"] is not None:
        lo, hi = r["winsor_0_5_99_5_lower"], r["winsor_0_5_99_5_upper"]
        winsor_df = winsor_df.withColumn(f"{c}__winsor", F.when(F.col(c) < lo, lo).when(F.col(c) > hi, hi).otherwise(F.col(c)))
    elif r["winsor_99"] is not None:
        q99 = r["winsor_99"]
        winsor_df = winsor_df.withColumn(f"{c}__winsor99", F.when(F.col(c) > q99, q99).otherwise(F.col(c)))

# 7) finish and timings
end = time.time()
print("Mode:", "fast (sample-based)" if fast_mode else "accurate (single-pass agg + sample quantiles)")
print("Sample used (n) for quantiles/topk:", base_n)
print("Elapsed seconds:", round(end-start,1))

qc_manifest = manifest_df
qc_winsorised_df = winsor_df
qc_manifest.toPandas().sort_values("pct_non_missing_over_source", ascending=False).head(80)
















































