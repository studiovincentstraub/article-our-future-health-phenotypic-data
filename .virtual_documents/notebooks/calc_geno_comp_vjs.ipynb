# Now do HES-derived small lookup (operate on merged_hes only)
# Keep only participant_pid and the fields needed for hospital_derives first
from pyspark.sql import functions as F

# Normalize HES column names if needed (same normalizer)
merged_hes = phenofhy.spark_utils.normalize_column_names_spark(merged_hes)

hospital_derives = [ "any_hospital_contact", "ae_visits", "apc_visits", "op_visits", "total_hospital_contacts"]

# run only these derives on the HES table
hes_derived = phenofhy.spark_process._run_derivations_auto_spark(
    merged_hes,
    hospital_derives,
    phenofhy.spark_derive_funcs.DERIVE_REGISTRY_SPARK
)


# 1) make safe column names (dots -> underscores) for both tables
new_hes_cols = [c.replace(".", "_") for c in hes_derived.columns]
hes_derived_safe = hes_derived.toDF(*new_hes_cols)

new_f_cols = [c.replace(".", "_") for c in f_sdf.columns]
f_sdf_safe = f_sdf.toDF(*new_f_cols)

# 2) now use safe names
pid_col = "participant_pid" if "participant_pid" in hes_derived_safe.columns else ("pid" if "pid" in hes_derived_safe.columns else None)
derived_cols = [f"derived_{c}" for c in hospital_derives]  # e.g. derived_any_hospital_contact

# 3) select, aggregate, join (same logic as before, but safe names)
sel_cols = [pid_col] + [c for c in derived_cols if c in hes_derived_safe.columns]
hes_sel = hes_derived_safe.select(*sel_cols)

from pyspark.sql import functions as F
agg_exprs = []
for orig in hospital_derives:
    colname = f"derived_{orig}"
    if colname not in hes_sel.columns:
        continue
    if orig == "any_hospital_contact":
        agg_exprs.append(F.max(F.col(colname).cast("int")).alias(orig))
    else:
        agg_exprs.append(F.sum(F.col(colname).cast("long")).alias(orig))

hes_lookup = hes_sel.groupBy(pid_col).agg(*agg_exprs)

# 4) align join key name if needed and join
if "participant_pid" in f_sdf_safe.columns and pid_col != "participant_pid":
    hes_lookup = hes_lookup.withColumnRenamed(pid_col, "participant_pid")
    join_on = "participant_pid"
else:
    join_on = pid_col

final_sdf = f_sdf_safe.join(hes_lookup, on=join_on, how="left")


